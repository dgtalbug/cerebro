        },
        "is_categorical": {
          "title": "Is Categorical",
          "type": "boolean"
        },
        "values": {
          "items": {
            "type": "number"
          },
          "title": "Values",
          "type": "array"
        }
      },
      "required": [
        "feature",
        "feature_index",
        "grid",
        "values",
        "is_categorical"
      ],
      "title": "PDPFeature",
      "type": "object"
    },
