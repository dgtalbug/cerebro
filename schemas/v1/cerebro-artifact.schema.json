        },
        "is_numeric": {
          "title": "Is Numeric",
          "type": "boolean"
        },
        "max": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max"
        },
        "mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean"
        },
        "min": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min"
        },
        "missingness": {
          "title": "Missingness",
          "type": "number"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "null_count": {
          "title": "Null Count",
          "type": "integer"
        },
        "std": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Std"
        },
        "top_categories": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/CategoryCount"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Top Categories"
        },
        "total_rows": {
          "title": "Total Rows",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "dtype",
        "is_numeric",
        "is_categorical",
        "total_rows",
        "null_count",
        "missingness"
      ],
