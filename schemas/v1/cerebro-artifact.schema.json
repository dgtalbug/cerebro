{
  "$defs": {
    "FeatureSchema": {
      "additionalProperties": false,
      "description": "The features the model sees, in input order.\n\n`monotone_constraints` has the same length as `names`. A value of 0 means\nno monotonicity is enforced; +1 / -1 enforce increasing / decreasing\nrelationships between the feature and the prediction.",
      "properties": {
        "categorical_indices": {
          "items": {
            "type": "integer"
          },
          "title": "Categorical Indices",
          "type": "array"
        },
        "monotone_constraints": {
          "items": {
            "type": "integer"
          },
          "title": "Monotone Constraints",
          "type": "array"
        },
        "names": {
          "items": {
            "type": "string"
          },
          "title": "Names",
          "type": "array"
        }
      },
      "required": [
        "names",
        "categorical_indices",
        "monotone_constraints"
      ],
      "title": "FeatureSchema",
      "type": "object"
    },
    "Importance": {
      "additionalProperties": false,
      "description": "Feature importance scores keyed by feature name.\n\n`permutation` is locked to None in v1.0.0. When permutation importance\nlands, it will use the shape `{feature_name: {\"mean\": float, \"std\": float}}`\nbehind a schema-version bump.",
      "properties": {
        "gain": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Gain",
          "type": "object"
        },
        "permutation": {
          "anyOf": [
            {
              "additionalProperties": {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Permutation"
        },
        "split": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Split",
          "type": "object"
        }
      },
      "required": [
        "gain",
        "split"
      ],
      "title": "Importance",
      "type": "object"
    },
    "Model": {
      "additionalProperties": false,
      "description": "Booster-level metadata: objective, parameters, feature shape.\n\n`params` is typed as `dict[str, Any]` because LightGBM stores a mix of\nscalars, lists, and nested dicts; tightening this would require enumerating\nevery LightGBM parameter and would still need updates when LightGBM adds\nparameters. The booster contract is what enforces shape \u2014 the extractor\nforwards what LightGBM gives us.",
      "properties": {
        "feature_schema": {
          "$ref": "#/$defs/FeatureSchema"
        },
        "num_class": {
          "const": 1,
          "title": "Num Class",
          "type": "integer"
        },
        "num_iteration": {
          "title": "Num Iteration",
          "type": "integer"
        },
        "objective": {
          "const": "binary",
          "title": "Objective",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        }
      },
      "required": [
        "objective",
        "num_class",
        "num_iteration",
        "params",
        "feature_schema"
      ],
      "title": "Model",
      "type": "object"
    },
    "Source": {
      "additionalProperties": false,
      "description": "Where this artifact came from and when.",
      "properties": {
        "extracted_at": {
          "title": "Extracted At",
          "type": "string"
        },
        "extractor_version": {
          "title": "Extractor Version",
          "type": "string"
        },
        "framework": {
          "const": "lightgbm",
          "title": "Framework",
          "type": "string"
        },
        "framework_version": {
          "title": "Framework Version",
          "type": "string"
        }
      },
      "required": [
        "framework",
        "framework_version",
        "extracted_at",
        "extractor_version"
      ],
      "title": "Source",
      "type": "object"
    },
    "Tree": {
      "additionalProperties": false,
      "description": "One tree in the ensemble.\n\n`class_index` is null for binary boosters; per-class trees in multiclass\nboosters set it to the class they predict (a future schema bump).",
      "properties": {
        "class_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Class Index"
        },
        "index": {
          "title": "Index",
          "type": "integer"
        },
        "num_leaves": {
          "title": "Num Leaves",
          "type": "integer"
        },
        "root": {
          "$ref": "#/$defs/TreeNode"
        }
      },
      "required": [
        "index",
        "num_leaves",
        "root"
      ],
      "title": "Tree",
      "type": "object"
    },
    "TreeNode": {
      "additionalProperties": false,
      "description": "One node in a decision tree (recursive).",
      "properties": {
        "decision_type": {
          "anyOf": [
            {
              "enum": [
                "<=",
                "=="
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Decision Type"
        },
        "id": {
          "title": "Id",
          "type": "integer"
        },
        "leaf_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Leaf Value"
        },
        "left": {
          "anyOf": [
            {
              "$ref": "#/$defs/TreeNode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "right": {
          "anyOf": [
            {
              "$ref": "#/$defs/TreeNode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "split_feature": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Split Feature"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold"
        }
      },
      "required": [
        "id"
      ],
      "title": "TreeNode",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The whole canonical artifact \u2014 the contract every layer agrees on.",
  "properties": {
    "evaluation": {
      "default": null,
      "title": "Evaluation",
      "type": "null"
    },
    "explanations": {
      "default": null,
      "title": "Explanations",
      "type": "null"
    },
    "importance": {
      "$ref": "#/$defs/Importance"
    },
    "model": {
      "$ref": "#/$defs/Model"
    },
    "schema_version": {
      "const": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/Source"
    },
    "trees": {
      "items": {
        "$ref": "#/$defs/Tree"
      },
      "title": "Trees",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "source",
    "model",
    "trees",
    "importance"
  ],
  "title": "CerebroArtifact",
  "type": "object"
}
