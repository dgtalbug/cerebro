    },
    "DecisionPath": {
      "additionalProperties": false,
      "description": "Traced path through a single tree for one sample.",
      "properties": {
        "leaf_value": {
          "title": "Leaf Value",
          "type": "number"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/DecisionStep"
