      "additionalProperties": false,
      "properties": {
        "actual": {
          "title": "Actual",
          "type": "number"
        },
        "predicted": {
          "title": "Predicted",
          "type": "number"
        }
      },
      "required": [
        "predicted",
        "actual"
      ],
      "title": "ScatterPoint",
      "type": "object"
    },
    "ShapResult": {
      "additionalProperties": false,
      "description": "SHAP values for a set of samples.\n\n`shap_values` has shape (n_samples, n_features) for binary and regression\nmodels. For multiclass it has shape (n_samples, n_classes, n_features),\nstored as a nested list.\n`expected_value` is a scalar for binary/regression; a list of per-class\nbase values for multiclass.",
      "properties": {
        "background_sample_count": {
          "title": "Background Sample Count",
          "type": "integer"
        },
        "expected_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            }
          ],
          "title": "Expected Value"
        },
        "feature_names": {
          "items": {
            "type": "string"
          },
          "title": "Feature Names",
          "type": "array"
        },
        "sample_count": {
          "title": "Sample Count",
          "type": "integer"
        },
        "shap_values": {
          "anyOf": [
            {
              "items": {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              "type": "array"
            },
            {
              "items": {
                "items": {
                  "items": {
                    "type": "number"
                  },
                  "type": "array"
                },
                "type": "array"
              },
              "type": "array"
            }
          ],
          "title": "Shap Values"
        }
      },
      "required": [
        "expected_value",
        "shap_values",
        "feature_names",
        "sample_count",
        "background_sample_count"
      ],
      "title": "ShapResult",
      "type": "object"
    },
    "Source": {
      "additionalProperties": false,
      "description": "Where this artifact came from and when.",
      "properties": {
        "extracted_at": {
          "title": "Extracted At",
          "type": "string"
        },
        "extractor_version": {
          "title": "Extractor Version",
          "type": "string"
        },
        "framework": {
          "const": "lightgbm",
          "title": "Framework",
          "type": "string"
        },
        "framework_version": {
          "title": "Framework Version",
          "type": "string"
        }
      },
      "required": [
        "framework",
        "framework_version",
        "extracted_at",
        "extractor_version"
      ],
      "title": "Source",
      "type": "object"
    },
    "Tree": {
      "additionalProperties": false,
      "description": "One tree in the ensemble.\n\n`class_index` is null for binary boosters; per-class trees in multiclass\nboosters set it to the class they predict (a future schema bump).",
      "properties": {
        "class_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Class Index"
        },
        "index": {
          "title": "Index",
          "type": "integer"
        },
        "num_leaves": {
          "title": "Num Leaves",
          "type": "integer"
        },
        "root": {
          "$ref": "#/$defs/TreeNode"
        }
      },
      "required": [
        "index",
        "num_leaves",
        "root"
      ],
      "title": "Tree",
      "type": "object"
    },
    "TreeNode": {
      "additionalProperties": false,
      "description": "One node in a decision tree (recursive).",
      "properties": {
        "decision_type": {
          "anyOf": [
            {
              "enum": [
                "<=",
                "=="
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Decision Type"
        },
        "id": {
          "title": "Id",
          "type": "integer"
        },
        "leaf_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Leaf Value"
        },
        "left": {
          "anyOf": [
            {
