          "type": "number"
        },
        "precision": {
          "title": "Precision",
          "type": "number"
        },
        "recall": {
          "title": "Recall",
          "type": "number"
        },
        "support": {
          "title": "Support",
          "type": "integer"
        }
      },
      "required": [
        "class_index",
        "precision",
        "recall",
        "f1",
        "support"
      ],
      "title": "PerClassMetrics",
      "type": "object"
    },
    "ROCPoint": {
      "additionalProperties": false,
      "properties": {
        "fpr": {
          "title": "Fpr",
          "type": "number"
        },
        "threshold": {
          "title": "Threshold",
          "type": "number"
        },
        "tpr": {
          "title": "Tpr",
          "type": "number"
        }
      },
      "required": [
        "fpr",
        "tpr",
        "threshold"
      ],
      "title": "ROCPoint",
      "type": "object"
    },
    "RankingEval": {
      "additionalProperties": false,
      "description": "Ranking (lambdarank) evaluation metrics.",
