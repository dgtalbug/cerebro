        "steps",
        "leaf_value"
      ],
      "title": "DecisionPath",
      "type": "object"
    },
    "DecisionStep": {
      "additionalProperties": false,
      "description": "One split node on the path from root to leaf.",
      "properties": {
        "decision_type": {
          "title": "Decision Type",
          "type": "string"
        },
        "feature_index": {
          "title": "Feature Index",
          "type": "integer"
        },
        "feature_name": {
          "title": "Feature Name",
          "type": "string"
        },
        "node_id": {
          "title": "Node Id",
          "type": "integer"
        },
        "sample_value": {
          "title": "Sample Value",
          "type": "number"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Threshold"
        },
        "went_left": {
          "title": "Went Left",
          "type": "boolean"
        }
      },
      "required": [
        "node_id",
        "feature_index",
        "feature_name",
        "threshold",
        "decision_type",
        "sample_value",
        "went_left"
      ],
      "title": "DecisionStep",
      "type": "object"
    },
    "Explanations": {
      "additionalProperties": false,
      "description": "Full explanations bundle stored in the artifact.",
      "properties": {
        "decision_paths": {
          "anyOf": [
            {
              "items": {
                "items": {
                  "$ref": "#/$defs/DecisionPath"
                },
                "type": "array"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Decision Paths"
        },
        "partial_dependence": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/PDPFeature"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Partial Dependence"
        },
        "shap": {
          "anyOf": [
            {
              "$ref": "#/$defs/ShapResult"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "Explanations",
      "type": "object"
    },
    "FeatureSchema": {
      "additionalProperties": false,
      "description": "The features the model sees, in input order.\n\n`monotone_constraints` has the same length as `names`. A value of 0 means\nno monotonicity is enforced; +1 / -1 enforce increasing / decreasing\nrelationships between the feature and the prediction.",
      "properties": {
        "categorical_indices": {
          "items": {
            "type": "integer"
          },
          "title": "Categorical Indices",
          "type": "array"
        },
        "monotone_constraints": {
          "items": {
            "type": "integer"
          },
          "title": "Monotone Constraints",
          "type": "array"
        },
        "names": {
          "items": {
            "type": "string"
          },
          "title": "Names",
          "type": "array"
        }
      },
      "required": [
        "names",
        "categorical_indices",
        "monotone_constraints"
      ],
      "title": "FeatureSchema",
      "type": "object"
    },
    "HistogramBin": {
      "additionalProperties": false,
      "properties": {
        "count": {
          "title": "Count",
          "type": "integer"
        },
        "lower": {
          "title": "Lower",
          "type": "number"
        },
        "upper": {
          "title": "Upper",
          "type": "number"
        }
      },
      "required": [
        "lower",
        "upper",
        "count"
      ],
      "title": "HistogramBin",
      "type": "object"
    },
    "Importance": {
      "additionalProperties": false,
      "description": "Feature importance scores keyed by feature name.",
      "properties": {
        "divergence_warnings": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    },
                    {
                      "type": "number"
                    }
                  ]
                },
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Divergence Warnings"
        },
        "gain": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Gain",
          "type": "object"
        },
        "permutation": {
          "anyOf": [
            {
              "additionalProperties": {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Permutation"
        },
        "split": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Split",
          "type": "object"
        }
      },
      "required": [
        "gain",
        "split"
      ],
      "title": "Importance",
      "type": "object"
    },
    "IntervalPoint": {
      "additionalProperties": false,
      "properties": {
        "lower": {
          "title": "Lower",
          "type": "number"
        },
        "predicted": {
          "title": "Predicted",
          "type": "number"
        },
        "upper": {
          "title": "Upper",
          "type": "number"
        }
      },
      "required": [
        "predicted",
        "lower",
        "upper"
      ],
      "title": "IntervalPoint",
      "type": "object"
    },
    "Model": {
      "additionalProperties": false,
      "description": "Booster-level metadata: objective, parameters, feature shape.\n\n`params` is typed as `dict[str, Any]` because LightGBM stores a mix of\nscalars, lists, and nested dicts; tightening this would require enumerating\nevery LightGBM parameter and would still need updates when LightGBM adds\nparameters. The booster contract is what enforces shape \u2014 the extractor\nforwards what LightGBM gives us.",
      "properties": {
        "feature_schema": {
          "$ref": "#/$defs/FeatureSchema"
        },
        "num_class": {
          "title": "Num Class",
          "type": "integer"
        },
        "num_iteration": {
          "title": "Num Iteration",
          "type": "integer"
        },
        "objective": {
          "enum": [
            "binary",
            "multiclass",
            "regression",
            "lambdarank",
            "multi_output"
          ],
          "title": "Objective",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        }
      },
      "required": [
        "objective",
        "num_class",
        "num_iteration",
        "params",
        "feature_schema"
      ],
      "title": "Model",
      "type": "object"
    },
    "MulticlassEval": {
