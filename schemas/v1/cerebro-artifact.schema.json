{
  "$defs": {
    "BinaryEval": {
      "additionalProperties": false,
      "description": "Binary classification evaluation metrics.",
      "properties": {
        "auc": {
          "title": "Auc",
          "type": "number"
        },
        "confusion_matrix": {
          "items": {
            "$ref": "#/$defs/ConfusionCell"
          },
          "title": "Confusion Matrix",
          "type": "array"
        },
        "f1": {
          "title": "F1",
          "type": "number"
        },
        "objective": {
          "const": "binary",
          "title": "Objective",
          "type": "string"
        },
        "precision": {
          "title": "Precision",
          "type": "number"
        },
        "recall": {
          "title": "Recall",
          "type": "number"
        },
        "roc_curve": {
          "items": {
            "$ref": "#/$defs/ROCPoint"
          },
          "title": "Roc Curve",
          "type": "array"
        },
        "threshold": {
          "title": "Threshold",
          "type": "number"
        }
      },
      "required": [
        "objective",
        "auc",
        "roc_curve",
        "confusion_matrix",
        "threshold",
        "precision",
        "recall",
        "f1"
      ],
      "title": "BinaryEval",
      "type": "object"
    },
