        },
        "macro_f1": {
          "title": "Macro F1",
          "type": "number"
        },
        "objective": {
          "const": "multiclass",
          "title": "Objective",
          "type": "string"
        },
        "per_class": {
          "items": {
            "$ref": "#/$defs/PerClassMetrics"
          },
          "title": "Per Class",
          "type": "array"
        }
      },
      "required": [
        "objective",
        "confusion_matrix",
        "per_class",
        "macro_f1",
        "accuracy"
      ],
      "title": "MulticlassEval",
      "type": "object"
    },
