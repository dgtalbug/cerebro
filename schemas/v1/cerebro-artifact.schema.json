        },
        "mae": {
          "title": "Mae",
          "type": "number"
        },
        "objective": {
          "const": "regression",
          "title": "Objective",
          "type": "string"
        },
        "r2": {
          "title": "R2",
          "type": "number"
        },
        "residuals_histogram": {
          "items": {
            "$ref": "#/$defs/HistogramBin"
          },
          "title": "Residuals Histogram",
